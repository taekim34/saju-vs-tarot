# Local development environment variables
# Copy this file to .env for local use

# bkend.ai Public Key (client-side, CORS-protected)
BKEND_API_KEY=pk_your_bkend_api_key_here

# OpenRouter API Key (only needed for local direct-call testing)
# In production, managed via Cloudflare Workers environment variables
# OPENROUTER_API_KEY=your_openrouter_key_here
